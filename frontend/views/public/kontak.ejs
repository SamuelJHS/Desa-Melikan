<!-- KONTAK & ASPIRASI -->
<section class="bg-gradient-to-br from-desa-primary to-desa-dark text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-xs font-bold tracking-widest uppercase text-desa-accent mb-2">Hubungi</div>
    <h1 class="font-serif text-5xl font-black" data-testid="page-title-kontak">Kontak & Aspirasi</h1>
    <p class="text-white/70 mt-2">Sampaikan pertanyaan, saran, atau aspirasi Anda</p>
  </div>
</section>

<section class="py-16 bg-desa-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10">
      <!-- Info Kontak -->
      <div>
        <h2 class="font-serif text-3xl font-black text-desa-dark mb-6">Informasi Kontak</h2>
        <% if (kontak) { %>
          <div class="space-y-4">
            <% if (kontak.alamat) { %>
            <div class="bg-white rounded-2xl p-5 border border-slate-200 flex gap-4">
              <div class="w-12 h-12 rounded-xl bg-desa-primary/10 text-desa-primary flex items-center justify-center flex-shrink-0"><i class="fas fa-location-dot text-xl"></i></div>
              <div>
                <div class="text-xs font-bold uppercase tracking-wider text-desa-secondary mb-1">Alamat Kantor</div>
                <div class="text-slate-700"><%= kontak.alamat %></div>
              </div>
            </div>
            <% } %>
            <% if (kontak.telepon || kontak.whatsapp) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <% if (kontak.telepon) { %>
              <div class="bg-white rounded-2xl p-5 border border-slate-200 flex gap-3">
                <div class="w-10 h-10 rounded-xl bg-desa-primary/10 text-desa-primary flex items-center justify-center flex-shrink-0"><i class="fas fa-phone"></i></div>
                <div>
                  <div class="text-xs font-bold uppercase tracking-wider text-desa-secondary">Telepon</div>
                  <div class="text-slate-700 text-sm"><%= kontak.telepon %></div>
                </div>
              </div>
              <% } %>
              <% if (kontak.whatsapp) { %>
              <div class="bg-white rounded-2xl p-5 border border-slate-200 flex gap-3">
                <div class="w-10 h-10 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center flex-shrink-0"><i class="fab fa-whatsapp"></i></div>
                <div>
                  <div class="text-xs font-bold uppercase tracking-wider text-desa-secondary">WhatsApp</div>
                  <div class="text-slate-700 text-sm"><%= kontak.whatsapp %></div>
                </div>
              </div>
              <% } %>
            </div>
            <% } %>
            <% if (kontak.email) { %>
            <div class="bg-white rounded-2xl p-5 border border-slate-200 flex gap-4">
              <div class="w-12 h-12 rounded-xl bg-desa-primary/10 text-desa-primary flex items-center justify-center flex-shrink-0"><i class="fas fa-envelope text-xl"></i></div>
              <div>
                <div class="text-xs font-bold uppercase tracking-wider text-desa-secondary mb-1">Email</div>
                <div class="text-slate-700"><%= kontak.email %></div>
              </div>
            </div>
            <% } %>
            <% if (kontak.jamPelayanan) { %>
            <div class="bg-white rounded-2xl p-5 border border-slate-200 flex gap-4">
              <div class="w-12 h-12 rounded-xl bg-desa-secondary/10 text-desa-secondary flex items-center justify-center flex-shrink-0"><i class="fas fa-clock text-xl"></i></div>
              <div>
                <div class="text-xs font-bold uppercase tracking-wider text-desa-secondary mb-1">Jam Pelayanan</div>
                <div class="text-slate-700"><%= kontak.jamPelayanan %></div>
              </div>
            </div>
            <% } %>

            <!-- Sosial Media -->
            <div class="flex flex-wrap gap-3 pt-4">
              <% if (kontak.instagram) { %><a href="https://instagram.com/<%= kontak.instagram.replace('@','') %>" target="_blank" class="w-12 h-12 rounded-full bg-pink-100 text-pink-600 hover:bg-pink-600 hover:text-white flex items-center justify-center transition"><i class="fab fa-instagram"></i></a><% } %>
              <% if (kontak.facebook) { %><a href="#" class="w-12 h-12 rounded-full bg-blue-100 text-blue-600 hover:bg-blue-600 hover:text-white flex items-center justify-center transition"><i class="fab fa-facebook"></i></a><% } %>
              <% if (kontak.youtube) { %><a href="#" class="w-12 h-12 rounded-full bg-red-100 text-red-600 hover:bg-red-600 hover:text-white flex items-center justify-center transition"><i class="fab fa-youtube"></i></a><% } %>
            </div>
          </div>
        <% } %>

        <!-- Google Maps -->
        <% if (kontak && kontak.googleMapsEmbed) { %>
          <div class="mt-6 rounded-2xl overflow-hidden border border-slate-200 aspect-video">
            <iframe src="<%= kontak.googleMapsEmbed %>" class="w-full h-full border-0" allowfullscreen></iframe>
          </div>
        <% } %>
      </div>

      <!-- Form Aspirasi -->
      <div>
        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-lg">
          <h2 class="font-serif text-3xl font-black text-desa-dark mb-2">Form Aspirasi</h2>
          <p class="text-sm text-slate-600 mb-6">Sampaikan aspirasi, saran, atau pertanyaan Anda kepada Pemerintah Desa.</p>

          <form action="/kontak" method="POST" class="space-y-4" data-testid="kontak-form">
            <div>
              <label class="block text-sm font-bold text-desa-dark mb-1.5">Nama Lengkap <span class="text-red-500">*</span></label>
              <input type="text" name="nama" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" data-testid="kontak-input-nama" />
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-bold text-desa-dark mb-1.5">Email <span class="text-red-500">*</span></label>
                <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" data-testid="kontak-input-email" />
              </div>
              <div>
                <label class="block text-sm font-bold text-desa-dark mb-1.5">No. Telepon</label>
                <input type="tel" name="telepon" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" data-testid="kontak-input-telepon" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-bold text-desa-dark mb-1.5">Subjek</label>
              <input type="text" name="subjek" placeholder="Aspirasi Masyarakat" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" data-testid="kontak-input-subjek" />
            </div>
            <div>
              <label class="block text-sm font-bold text-desa-dark mb-1.5">Pesan / Aspirasi <span class="text-red-500">*</span></label>
              <textarea name="pesan" required rows="6" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none resize-none" data-testid="kontak-input-pesan"></textarea>
            </div>
            <button type="submit" class="w-full bg-desa-primary text-white px-6 py-3.5 rounded-xl font-bold hover:bg-desa-dark transition shadow-lg" data-testid="kontak-submit-btn">
              <i class="fas fa-paper-plane mr-2"></i>Kirim Aspirasi
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
