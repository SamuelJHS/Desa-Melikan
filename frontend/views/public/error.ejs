<section class="min-h-[60vh] flex items-center justify-center bg-desa-cream">
  <div class="text-center px-4 max-w-xl">
    <i class="fas fa-circle-exclamation text-6xl text-red-500 mb-4"></i>
    <h1 class="font-serif text-3xl font-black text-desa-dark mb-2">Terjadi Kesalahan</h1>
    <p class="text-slate-600 mb-2">Maaf, ada masalah saat memproses permintaan Anda.</p>
    <% if (error) { %><pre class="text-xs text-red-500 bg-red-50 p-3 rounded-lg overflow-auto mb-6"><%= error %></pre><% } %>
    <a href="/" class="inline-flex items-center gap-2 bg-desa-primary text-white px-6 py-3 rounded-full font-bold hover:bg-desa-dark transition">
      <i class="fas fa-home"></i> Kembali ke Beranda
    </a>
  </div>
</section>
