<!-- PROFIL DESA -->
<section class="bg-gradient-to-br from-desa-primary to-desa-dark text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-xs font-bold tracking-widest uppercase text-desa-accent mb-2">Profil</div>
    <h1 class="font-serif text-5xl font-black" data-testid="page-title-profil">Profil Desa</h1>
    <p class="text-white/70 mt-2">Mengenal lebih dekat <%= profil ? profil.namaDesa : 'desa kami' %></p>
  </div>
</section>

<% if (profil) { %>
<!-- Sejarah -->
<section class="py-16 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <div>
        <div class="text-xs font-bold tracking-widest uppercase text-desa-secondary mb-2">01 — Sejarah</div>
        <h2 class="font-serif text-3xl font-black text-desa-dark">Jejak Langkah <%= profil.namaDesa %></h2>
      </div>
      <div class="lg:col-span-2 prose prose-slate max-w-none">
        <p class="text-slate-700 leading-relaxed whitespace-pre-line"><%= profil.sejarah || 'Belum ada informasi sejarah.' %></p>
      </div>
    </div>
  </div>
</section>

<!-- Visi Misi -->
<section class="py-16 bg-desa-cream">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-desa-secondary mb-2">02 — Visi & Misi</div>
      <h2 class="font-serif text-3xl font-black text-desa-dark">Arah Pembangunan Desa</h2>
    </div>

    <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-lg border border-slate-200 mb-6">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-desa-primary text-white flex items-center justify-center flex-shrink-0">
          <i class="fas fa-eye text-xl"></i>
        </div>
        <div>
          <h3 class="text-sm font-bold text-desa-primary uppercase tracking-widest mb-3">Visi</h3>
          <p class="font-serif text-xl lg:text-2xl text-desa-dark italic leading-relaxed">"<%= profil.visi %>"</p>
        </div>
      </div>
    </div>

    <% if (profil.misi && profil.misi.length) { %>
    <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-lg border border-slate-200">
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 rounded-xl bg-desa-secondary text-white flex items-center justify-center flex-shrink-0">
          <i class="fas fa-list-check text-xl"></i>
        </div>
        <div>
          <h3 class="text-sm font-bold text-desa-secondary uppercase tracking-widest">Misi</h3>
        </div>
      </div>
      <ol class="space-y-4">
        <% profil.misi.forEach((m, i) => { %>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-desa-secondary/10 text-desa-secondary font-bold flex items-center justify-center text-sm"><%= i+1 %></span>
            <span class="text-slate-700 leading-relaxed pt-1"><%= m %></span>
          </li>
        <% }) %>
      </ol>
    </div>
    <% } %>
  </div>
</section>

<!-- Struktur Organisasi -->
<% if (profil.struktur && profil.struktur.length) { %>
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-desa-secondary mb-2">03 — Pemerintahan</div>
      <h2 class="font-serif text-3xl font-black text-desa-dark">Struktur Organisasi</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% profil.struktur.forEach(s => { %>
        <div class="bg-gradient-to-br from-desa-cream to-white border border-slate-200 rounded-2xl p-6 text-center hover:shadow-lg transition" data-testid="struktur-card">
          <div class="w-20 h-20 mx-auto rounded-full bg-desa-primary text-white flex items-center justify-center text-3xl font-bold mb-4">
            <%= s.nama.charAt(0) %>
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-desa-secondary mb-1"><%= s.jabatan %></div>
          <div class="font-serif font-bold text-lg text-desa-dark"><%= s.nama %></div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- 04 - Informasi Wilayah -->
<section class="bg-gradient-to-br from-desa-primary to-desa-dark text-white py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-desa-accent mb-2">04 — Geografi</div>
      <h2 class="font-serif text-3xl font-black">Informasi Wilayah</h2>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
        <i class="fas fa-map text-desa-accent text-2xl mb-3"></i>
        <div class="text-xs uppercase tracking-wider text-white/60">Luas Wilayah</div>
        <div class="font-bold text-lg mt-1"><%= profil.luasWilayah || '-' %></div>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
        <i class="fas fa-users text-desa-accent text-2xl mb-3"></i>
        <div class="text-xs uppercase tracking-wider text-white/60">Penduduk</div>
        <div class="font-bold text-lg mt-1"><%= profil.jumlahPenduduk || '-' %></div>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
        <i class="fas fa-house-user text-desa-accent text-2xl mb-3"></i>
        <div class="text-xs uppercase tracking-wider text-white/60">Jumlah KK</div>
        <div class="font-bold text-lg mt-1"><%= profil.jumlahKK || '-' %></div>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
        <i class="fas fa-location-dot text-desa-accent text-2xl mb-3"></i>
        <div class="text-xs uppercase tracking-wider text-white/60">Lokasi</div>
        <div class="font-bold text-sm mt-1"><%= profil.kecamatan %>, <%= profil.kabupaten %></div>
      </div>
    </div>
  </div>
</section>

<!-- 05 - Denah Wilayah -->
<section class="py-16 bg-desa-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="text-xs font-bold tracking-widest uppercase text-desa-secondary mb-2">05 — Denah</div>
      <h2 class="font-serif text-3xl font-black text-desa-dark">Denah Wilayah</h2>
    </div>
    <div class="bg-white rounded-3xl shadow-2xl p-6 overflow-hidden border border-slate-200">
      <img src="<%= profil.denahWilayah ? '/uploads/' + profil.denahWilayah : '/static/images/DENAH.png' %>" alt="Denah Wilayah <%= profil.namaDesa %>" class="w-full h-auto rounded-2xl" />
    </div>
  </div>
</section>

<% } else { %>
<div class="max-w-4xl mx-auto py-20 text-center">
  <p class="text-slate-500">Profil desa belum tersedia.</p>
</div>
<% } %>
