<!-- BERITA DETAIL -->
<section class="bg-desa-cream py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <a href="/berita" class="inline-flex items-center text-desa-primary font-bold mb-6 hover:underline">
      <i class="fas fa-arrow-left mr-2"></i>Kembali ke Berita
    </a>

    <article class="bg-white rounded-3xl overflow-hidden shadow-xl border border-slate-200">
      <% if (item.gambar) { %>
        <div class="aspect-[16/9] bg-slate-100 overflow-hidden">
          <img src="<%= item.gambar %>" alt="<%= item.judul %>" class="w-full h-full object-cover" />
        </div>
      <% } %>
      <div class="p-8 lg:p-12">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="bg-desa-accent text-desa-dark text-xs font-bold px-3 py-1 rounded-full"><%= item.kategori %></span>
          <span class="text-xs text-slate-500"><i class="fas fa-calendar mr-1"></i><%= new Date(item.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %></span>
          <span class="text-xs text-slate-500"><i class="fas fa-user mr-1"></i><%= item.penulis %></span>
          <span class="text-xs text-slate-500"><i class="fas fa-eye mr-1"></i><%= item.views %> dilihat</span>
        </div>

        <h1 class="font-serif text-3xl lg:text-5xl font-black text-desa-dark mb-6 leading-tight" data-testid="berita-detail-title"><%= item.judul %></h1>

        <% if (item.ringkasan) { %>
          <p class="text-lg text-slate-600 italic border-l-4 border-desa-primary pl-4 mb-6"><%= item.ringkasan %></p>
        <% } %>

        <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed">
          <%- item.konten %>
        </div>
      </div>
    </article>

    <% if (related && related.length) { %>
    <div class="mt-16">
      <h3 class="font-serif text-2xl font-black text-desa-dark mb-6">Berita Terkait</h3>
      <div class="grid md:grid-cols-3 gap-6">
        <% related.forEach(r => { %>
          <a href="/berita/<%= r.slug %>" class="group bg-white rounded-2xl overflow-hidden border border-slate-200 hover:shadow-xl transition">
            <div class="aspect-[16/10] bg-slate-100 overflow-hidden">
              <% if (r.gambar) { %>
                <img src="<%= r.gambar %>" alt="<%= r.judul %>" class="w-full h-full object-cover" />
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-desa-primary/20 to-desa-secondary/20 text-desa-primary"><i class="fas fa-newspaper text-4xl"></i></div>
              <% } %>
            </div>
            <div class="p-4">
              <h4 class="font-serif font-bold text-base text-desa-dark group-hover:text-desa-primary transition line-clamp-2"><%= r.judul %></h4>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</section>
