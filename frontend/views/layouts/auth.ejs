<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Desa Melikan</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,700;9..144,900&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Plus Jakarta Sans', 'sans-serif'],
            serif: ['Fraunces', 'serif'],
          },
          colors: {
            desa: { primary: '#2563eb', secondary: '#C2410C', accent: '#F59E0B', cream: '#FBF7F0', dark: '#1A2E1F' },
          },
        },
      },
    };
  </script>
</head>
<body class="font-sans antialiased min-h-screen flex items-center justify-center p-4" style="background: linear-gradient(135deg, #2563eb 0%, #1A2E1F 100%);">
  <%- body %>
</body>
</html>
