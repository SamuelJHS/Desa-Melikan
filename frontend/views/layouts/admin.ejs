<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Admin Desa Melikan</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
          colors: {
            desa: {
              primary: '#2563eb',
              secondary: '#C2410C',
              accent: '#F59E0B',
              dark: '#1A2E1F',
            },
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/static/css/admin.css" />
</head>
<body class="font-sans bg-slate-100 text-slate-800 antialiased">
  <div class="flex min-h-screen">
    <%- include('../partials/admin-sidebar') %>

    <div class="flex-1 lg:ml-64">
      <!-- Topbar -->
      <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
        <div class="flex items-center justify-between px-6 py-4">
          <div class="flex items-center gap-3">
            <button id="sidebarToggle" class="lg:hidden text-slate-600" data-testid="admin-sidebar-toggle">
              <i class="fas fa-bars text-xl"></i>
            </button>
            <h1 class="text-xl font-bold text-slate-800" data-testid="admin-page-title"><%= title %></h1>
          </div>
          <div class="flex items-center gap-4">
            <a href="/" target="_blank" class="text-sm text-slate-600 hover:text-desa-primary" data-testid="admin-view-public-link">
              <i class="fas fa-external-link-alt mr-1"></i> Lihat Website
            </a>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-desa-primary text-white flex items-center justify-center text-sm font-bold">
                <%= admin.name.charAt(0).toUpperCase() %>
              </div>
              <span class="hidden md:inline text-sm font-medium" data-testid="admin-name"><%= admin.name %></span>
            </div>
          </div>
        </div>
      </header>

      <!-- Flash -->
      <% if (success_msg && success_msg.length) { %>
        <div class="mx-6 mt-4 bg-blue-50 border-l-4 border-blue-500 text-blue-700 px-4 py-3 rounded" data-testid="admin-flash-success">
          <i class="fas fa-check-circle mr-2"></i><%= success_msg %>
        </div>
      <% } %>
      <% if (error_msg && error_msg.length) { %>
        <div class="mx-6 mt-4 bg-red-50 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded" data-testid="admin-flash-error">
          <i class="fas fa-exclamation-circle mr-2"></i><%= error_msg %>
        </div>
      <% } %>

      <!-- Main Content -->
      <main class="p-6">
        <%- body %>
      </main>
    </div>
  </div>

  <script>
    // Toggle sidebar mobile
    const toggle = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('adminSidebar');
    toggle?.addEventListener('click', () => sidebar.classList.toggle('-translate-x-full'));
  </script>
</body>
</html>
