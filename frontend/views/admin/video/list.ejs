<!-- VIDEO LIST -->
<div class="bg-white rounded-2xl p-6 border border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-bold text-lg text-slate-800">Daftar Video (<%= video.length %>)</h2>
    <a href="/admin/video/tambah" class="bg-desa-primary text-white px-4 py-2 rounded-lg font-semibold hover:bg-desa-dark transition">
      <i class="fas fa-plus mr-1"></i> Tambah Video
    </a>
  </div>

  <% if (video.length === 0) { %>
    <div class="text-center py-12 text-slate-500"><i class="fas fa-video text-5xl mb-4"></i><p>Belum ada video.</p></div>
  <% } else { %>
    <div class="grid md:grid-cols-2 gap-4">
      <% video.forEach(v => { %>
        <div class="bg-slate-50 rounded-xl overflow-hidden border border-slate-200">
          <div class="aspect-video bg-black">
            <% if (v.tipe === 'youtube' && v.youtubeId) { %>
              <iframe src="https://www.youtube.com/embed/<%= v.youtubeId %>" class="w-full h-full" allowfullscreen></iframe>
            <% } else if (v.filePath) { %>
              <video controls class="w-full h-full"><source src="<%= v.filePath %>" /></video>
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-white"><i class="fas fa-video text-4xl"></i></div>
            <% } %>
          </div>
          <div class="p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1">
                <div class="font-bold text-slate-800 mb-1"><%= v.judul %></div>
                <div class="text-xs text-slate-500"><%= v.tipe === 'youtube' ? 'YouTube' : 'File Lokal' %> <%= v.featured ? '• ⭐ Featured' : '' %></div>
              </div>
              <div class="flex gap-1">
                <a href="/admin/video/edit/<%= v._id %>" class="w-8 h-8 flex items-center justify-center rounded-lg bg-blue-100 text-blue-600 hover:bg-blue-200"><i class="fas fa-pen text-xs"></i></a>
                <form action="/admin/video/hapus/<%= v._id %>" method="POST" onsubmit="return confirm('Yakin hapus?')">
                  <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-100 text-red-600 hover:bg-red-200"><i class="fas fa-trash text-xs"></i></button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
