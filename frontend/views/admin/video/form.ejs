<!-- VIDEO FORM -->
<div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-bold text-lg text-slate-800"><%= item ? 'Edit Video' : 'Tambah Video Baru' %></h2>
    <a href="/admin/video" class="text-sm text-slate-600 hover:text-desa-primary"><i class="fas fa-arrow-left mr-1"></i> Kembali</a>
  </div>

  <form action="<%= item ? '/admin/video/edit/' + item._id : '/admin/video/tambah' %>" method="POST" enctype="multipart/form-data" class="space-y-5">
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Judul Video <span class="text-red-500">*</span></label>
      <input type="text" name="judul" required value="<%= item ? item.judul : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Deskripsi</label>
      <textarea name="deskripsi" rows="3" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none resize-none"><%= item ? item.deskripsi : '' %></textarea>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Tipe Video <span class="text-red-500">*</span></label>
      <div class="flex gap-3">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="tipe" value="youtube" <%= !item || item.tipe === 'youtube' ? 'checked' : '' %> onchange="toggleVideoType()" />
          <span>YouTube Embed</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="tipe" value="lokal" <%= item && item.tipe === 'lokal' ? 'checked' : '' %> onchange="toggleVideoType()" />
          <span>Upload File Lokal</span>
        </label>
      </div>
    </div>

    <div id="ytField">
      <label class="block text-sm font-bold text-slate-700 mb-1.5">URL YouTube atau ID Video</label>
      <input type="text" name="youtubeInput" value="<%= item && item.youtubeId ? item.youtubeId : '' %>" placeholder="https://youtube.com/watch?v=xxxxx atau ID langsung" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      <p class="text-xs text-slate-500 mt-1">Bisa berupa URL lengkap, URL share (youtu.be/...), atau ID 11 karakter.</p>
    </div>

    <div id="fileField" class="hidden">
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Upload File Video</label>
      <% if (item && item.filePath) { %><div class="text-xs text-slate-500 mb-2">File saat ini: <%= item.filePath %></div><% } %>
      <input type="file" name="file" accept="video/*" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:font-bold file:bg-desa-primary file:text-white hover:file:bg-desa-dark" />
      <p class="text-xs text-slate-500 mt-1">Max 50 MB. Format: MP4, WebM, MOV.</p>
    </div>

    <div class="flex items-center gap-2">
      <input type="checkbox" name="featured" id="featured" <%= item && item.featured ? 'checked' : '' %> class="w-4 h-4 accent-desa-accent" />
      <label for="featured" class="text-sm font-semibold text-slate-700">Jadikan video utama (tampil di beranda)</label>
    </div>

    <div class="flex gap-3 pt-4 border-t border-slate-200">
      <button type="submit" class="bg-desa-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-desa-dark transition">
        <i class="fas fa-save mr-2"></i><%= item ? 'Update' : 'Simpan' %>
      </button>
      <a href="/admin/video" class="px-6 py-3 rounded-lg font-bold border border-slate-300 hover:bg-slate-100 transition">Batal</a>
    </div>
  </form>
</div>

<script>
  function toggleVideoType() {
    const tipe = document.querySelector('input[name="tipe"]:checked').value;
    document.getElementById('ytField').classList.toggle('hidden', tipe !== 'youtube');
    document.getElementById('fileField').classList.toggle('hidden', tipe !== 'lokal');
  }
  toggleVideoType();
</script>
