<!-- BERITA FORM -->
<div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-bold text-lg text-slate-800"><%= item ? 'Edit Berita' : 'Tambah Berita Baru' %></h2>
    <a href="/admin/berita" class="text-sm text-slate-600 hover:text-desa-primary"><i class="fas fa-arrow-left mr-1"></i> Kembali</a>
  </div>

  <form action="<%= item ? '/admin/berita/edit/' + item._id : '/admin/berita/tambah' %>" method="POST" enctype="multipart/form-data" class="space-y-5" data-testid="berita-form">
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Judul Berita <span class="text-red-500">*</span></label>
      <input type="text" name="judul" required value="<%= item ? item.judul : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" data-testid="input-judul" />
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Kategori</label>
        <input type="text" name="kategori" value="<%= item ? item.kategori : 'Umum' %>" placeholder="Kegiatan, Pembangunan, Kesehatan..." class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Penulis</label>
        <input type="text" name="penulis" value="<%= item ? item.penulis : admin.name %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Ringkasan (opsional)</label>
      <textarea name="ringkasan" rows="2" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none resize-none"><%= item ? item.ringkasan : '' %></textarea>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Konten Berita <span class="text-red-500">*</span></label>
      <textarea name="konten" required rows="12" placeholder="Tulis isi berita di sini... (mendukung HTML)" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none font-mono text-sm"><%= item ? item.konten : '' %></textarea>
      <p class="text-xs text-slate-500 mt-1">Tip: Gunakan tag <code>&lt;p&gt;</code>, <code>&lt;strong&gt;</code>, <code>&lt;br&gt;</code> untuk formatting.</p>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Gambar Berita</label>
      <% if (item && item.gambar) { %>
        <img src="<%= item.gambar %>" class="w-40 h-28 rounded-lg object-cover mb-3" />
      <% } %>
      <input type="file" name="gambar" accept="image/*" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:font-bold file:bg-desa-primary file:text-white hover:file:bg-desa-dark" />
    </div>

    <div class="flex items-center gap-2">
      <input type="checkbox" name="published" id="published" <%= !item || item.published ? 'checked' : '' %> class="w-4 h-4 accent-desa-primary" />
      <label for="published" class="text-sm font-semibold text-slate-700">Publikasikan berita ini</label>
    </div>

    <div class="flex gap-3 pt-4 border-t border-slate-200">
      <button type="submit" class="bg-desa-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-desa-dark transition" data-testid="btn-simpan-berita">
        <i class="fas fa-save mr-2"></i><%= item ? 'Update Berita' : 'Simpan Berita' %>
      </button>
      <a href="/admin/berita" class="px-6 py-3 rounded-lg font-bold border border-slate-300 hover:bg-slate-100 transition">Batal</a>
    </div>
  </form>
</div>
