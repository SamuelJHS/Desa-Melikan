<!-- GALERI FORM -->
<div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-bold text-lg text-slate-800"><%= item ? 'Edit Foto Galeri' : 'Upload Foto Baru' %></h2>
    <a href="/admin/galeri" class="text-sm text-slate-600 hover:text-desa-primary"><i class="fas fa-arrow-left mr-1"></i> Kembali</a>
  </div>

  <form action="<%= item ? '/admin/galeri/edit/' + item._id : '/admin/galeri/tambah' %>" method="POST" enctype="multipart/form-data" class="space-y-5">
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Judul Foto <span class="text-red-500">*</span></label>
      <input type="text" name="judul" required value="<%= item ? item.judul : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Kategori</label>
      <input type="text" name="kategori" value="<%= item ? item.kategori : 'Umum' %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Deskripsi (opsional)</label>
      <textarea name="deskripsi" rows="3" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none resize-none"><%= item ? item.deskripsi : '' %></textarea>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">File Gambar <%= !item ? '<span class="text-red-500">*</span>' : '(kosongkan jika tidak ingin diganti)' %></label>
      <% if (item && item.gambar) { %><img src="<%= item.gambar %>" class="w-40 h-40 rounded-lg object-cover mb-3" /><% } %>
      <input type="file" name="gambar" accept="image/*" <%= !item ? 'required' : '' %> class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:font-bold file:bg-desa-primary file:text-white hover:file:bg-desa-dark" />
    </div>

    <div class="flex gap-3 pt-4 border-t border-slate-200">
      <button type="submit" class="bg-desa-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-desa-dark transition">
        <i class="fas fa-save mr-2"></i><%= item ? 'Update' : 'Upload' %>
      </button>
      <a href="/admin/galeri" class="px-6 py-3 rounded-lg font-bold border border-slate-300 hover:bg-slate-100 transition">Batal</a>
    </div>
  </form>
</div>
