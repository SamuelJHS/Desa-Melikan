<!-- GALERI LIST -->
<div class="bg-white rounded-2xl p-6 border border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-bold text-lg text-slate-800">Galeri Foto (<%= galeri.length %>)</h2>
    <a href="/admin/galeri/tambah" class="bg-desa-primary text-white px-4 py-2 rounded-lg font-semibold hover:bg-desa-dark transition" data-testid="btn-tambah-galeri">
      <i class="fas fa-plus mr-1"></i> Upload Foto
    </a>
  </div>

  <% if (galeri.length === 0) { %>
    <div class="text-center py-12 text-slate-500"><i class="fas fa-images text-5xl mb-4"></i><p>Belum ada foto di galeri.</p></div>
  <% } else { %>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      <% galeri.forEach(g => { %>
        <div class="bg-slate-50 rounded-xl overflow-hidden border border-slate-200">
          <div class="aspect-square overflow-hidden">
            <img src="<%= g.gambar %>" class="w-full h-full object-cover" />
          </div>
          <div class="p-3">
            <div class="font-semibold text-sm text-slate-800 line-clamp-1"><%= g.judul %></div>
            <div class="text-xs text-slate-500 mb-3"><%= g.kategori %></div>
            <div class="flex gap-1">
              <a href="/admin/galeri/edit/<%= g._id %>" class="flex-1 text-center text-xs py-1.5 rounded-lg bg-blue-100 text-blue-600 hover:bg-blue-200 font-semibold">Edit</a>
              <form action="/admin/galeri/hapus/<%= g._id %>" method="POST" class="flex-1" onsubmit="return confirm('Yakin hapus?')">
                <button type="submit" class="w-full text-xs py-1.5 rounded-lg bg-red-100 text-red-600 hover:bg-red-200 font-semibold">Hapus</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
