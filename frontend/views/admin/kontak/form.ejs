<!-- KONTAK FORM -->
<form action="/admin/kontak" method="POST" class="space-y-6">
  <div class="bg-white rounded-2xl p-6 border border-slate-200">
    <h3 class="font-bold text-base text-slate-800 mb-4 pb-3 border-b border-slate-200"><i class="fas fa-address-card text-desa-primary mr-2"></i>Informasi Kontak Resmi</h3>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Alamat</label>
        <textarea name="alamat" rows="2" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none resize-none"><%= kontak.alamat %></textarea>
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Telepon</label>
        <input type="text" name="telepon" value="<%= kontak.telepon %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">WhatsApp</label>
        <input type="text" name="whatsapp" value="<%= kontak.whatsapp %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Email</label>
        <input type="email" name="email" value="<%= kontak.email %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Website</label>
        <input type="text" name="website" value="<%= kontak.website %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Instagram</label>
        <input type="text" name="instagram" value="<%= kontak.instagram %>" placeholder="@username" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Facebook</label>
        <input type="text" name="facebook" value="<%= kontak.facebook %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">YouTube</label>
        <input type="text" name="youtube" value="<%= kontak.youtube %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Jam Pelayanan</label>
        <input type="text" name="jamPelayanan" value="<%= kontak.jamPelayanan %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Google Maps Embed (src)</label>
        <input type="text" name="googleMapsEmbed" value="<%= kontak.googleMapsEmbed %>" placeholder="https://www.google.com/maps/embed?pb=..." class="w-full px-4 py-2.5 rounded-lg border border-slate-300" />
        <p class="text-xs text-slate-500 mt-1">Buka Google Maps → Share → Embed → salin URL dari atribut <code>src</code>.</p>
      </div>
    </div>
  </div>
  <button type="submit" class="bg-desa-primary text-white px-8 py-3 rounded-lg font-bold hover:bg-desa-dark transition shadow-lg">
    <i class="fas fa-save mr-2"></i>Simpan Kontak
  </button>
</form>
