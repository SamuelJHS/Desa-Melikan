<!-- POTENSI FORM -->
<div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-200">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-bold text-lg text-slate-800"><%= item ? 'Edit Potensi' : 'Tambah Potensi Baru' %></h2>
    <a href="/admin/potensi" class="text-sm text-slate-600 hover:text-desa-primary"><i class="fas fa-arrow-left mr-1"></i> Kembali</a>
  </div>

  <form action="<%= item ? '/admin/potensi/edit/' + item._id : '/admin/potensi/tambah' %>" method="POST" enctype="multipart/form-data" class="space-y-5">
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Nama Potensi <span class="text-red-500">*</span></label>
        <input type="text" name="nama" required value="<%= item ? item.nama : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Kategori <span class="text-red-500">*</span></label>
        <select name="kategori" required class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none">
          <% ['Wisata', 'UMKM', 'Produk Unggulan', 'Pertanian', 'Lainnya'].forEach(k => { %>
            <option value="<%= k %>" <%= item && item.kategori === k ? 'selected' : '' %>><%= k %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Harga (opsional)</label>
        <input type="text" name="harga" value="<%= item ? item.harga : '' %>" placeholder="Mulai Rp 50.000" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Lokasi</label>
        <input type="text" name="lokasi" value="<%= item ? item.lokasi : '' %>" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5">Kontak</label>
        <input type="text" name="kontak" value="<%= item ? item.kontak : '' %>" placeholder="No. HP / WhatsApp" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Deskripsi <span class="text-red-500">*</span></label>
      <textarea name="deskripsi" required rows="6" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-desa-primary focus:ring-4 focus:ring-desa-primary/20 outline-none resize-none"><%= item ? item.deskripsi : '' %></textarea>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5">Gambar</label>
      <% if (item && item.gambar) { %><img src="<%= item.gambar %>" class="w-40 h-28 rounded-lg object-cover mb-3" /><% } %>
      <input type="file" name="gambar" accept="image/*" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:font-bold file:bg-desa-primary file:text-white hover:file:bg-desa-dark" />
    </div>

    <div class="flex items-center gap-2">
      <input type="checkbox" name="featured" id="featured" <%= item && item.featured ? 'checked' : '' %> class="w-4 h-4 accent-desa-accent" />
      <label for="featured" class="text-sm font-semibold text-slate-700">Tandai sebagai potensi unggulan (akan ditampilkan di beranda)</label>
    </div>

    <div class="flex gap-3 pt-4 border-t border-slate-200">
      <button type="submit" class="bg-desa-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-desa-dark transition">
        <i class="fas fa-save mr-2"></i><%= item ? 'Update' : 'Simpan' %>
      </button>
      <a href="/admin/potensi" class="px-6 py-3 rounded-lg font-bold border border-slate-300 hover:bg-slate-100 transition">Batal</a>
    </div>
  </form>
</div>
